    % Svart lina = lina 2 = botten → boj (nedåt)
    set(h_line2, 'XData', [r_botten(1), mitten_undre_boj(1)], ... 
                 'YData', [r_botten(2), mitten_undre_boj(2)]);
    set(h_turbin, 'XData',  horn_varld_turbin(1,:), 'YData',  horn_varld_turbin(2,:));

    drawnow
end

%% Funktioner

function dydt = f(~, y, V_boj, m_boj, bredd_turbin, djup_turbin, m_turbin, ...   % ~ ska vara t
                  r_botten, L0_1, L0_2, k, ...
                  U_strom_boj, U_strom_turbin, ...
                  A_boj, Cd, p, horn_boj, horn_turbin)

    % Boj
    r_boj = y(1:2)';
    v_boj = y(3:4)';
    r_horn_1_boj = r_boj + (horn_boj(:,1)    + horn_boj(:,2))/2;  % nedre vänstra hörnet mot botten
    r_horn_2_boj = r_boj +(horn_boj(:,3)    + horn_boj(:,4))/2;  % nedre högra hörnet mot turbinen

    % Turbin
    r_turbin = y(5:6)';
    v_turbin = y(7:8)';
    r_horn_1_turbin = r_turbin + (horn_turbin(:,1) + horn_turbin(:,2)) / 2;   % nedre högra hörnet
    hojd_turbin_vatten = abs(r_horn_1_turbin(2));
    V_turbin = bredd_turbin*djup_turbin*hojd_turbin_vatten;
    A_turbin = djup_turbin*hojd_turbin_vatten;

    % Krafter på bojen
    Fdrag_boj = F_drag(U_strom_boj, v_boj, A_boj, Cd, p);
    Fflyt_boj = flyt(V_boj);
    Ftyngd_boj = tyngd(m_boj);
    Flin_1 = F_lin(r_horn_2_boj, r_horn_1_turbin, L0_1, k);
    Flin_2 = F_lin(r_horn_1_boj, r_botten, L0_2, k);

    Ftot_boj = Fflyt_boj + Ftyngd_boj + Flin_1 + Flin_2 + Fdrag_boj;
    a_boj = Ftot_boj / m_boj;

    % Krafter på turbinen
    Fdrag_turbin = F_drag(U_strom_turbin, v_turbin, A_turbin, Cd, p);
    Fflyt_turbin = flyt(V_turbin);
    Ftyngd_turbin = tyngd(m_turbin);
    Flin_turbin = F_lin(r_horn_1_turbin, r_horn_2_boj, L0_1, k);

    Ftot_turbin = Fflyt_turbin + Ftyngd_turbin + Flin_turbin + Fdrag_turbin;
    a_turbin = Ftot_turbin / m_turbin;

    dydt = [v_boj; a_boj; v_turbin; a_turbin];
    dydt = dydt(:)';
end

% Tyngdkraft
function Ftyngd = tyngd(m)
    g = 9.82;
    Ftyngd = [0; -m * g];      
end

% Arkimedes princip
function Fflyt = flyt(V)  % Varje kraft är en 2x1 vektor med [x-komponent; z-komponent]
    p = 1000;
    g = 9.82;
    Fflyt = [0; p * g * V];  
end

% Dragkraft 
function Fdrag = F_drag(U_strom, v, A, Cd, p)
    v_rel = U_strom - v;        
    Fdrag = 0.5 * p * A * Cd * norm(v_rel) * v_rel;
end

% Hookes lag
function Flin = F_lin(r1, r0, L0, k)
    r1 = r1(:);
    r0 = r0(:);
    d = r1 - r0;
    L = norm(d);

    if L == 0
        Flin = [0; 0];
        return
    end

    e = d / L;
    T = k * max(L - L0, 0);
    Flin = -T * e;
end

function [t, y] = rk4(f, tspan, y0, h)
    nsteps = floor((tspan(2) - tspan(1)) / h);
    m = length(y0);

    t = zeros(nsteps + 1, 1);
    y = zeros(nsteps + 1, m);

    t(1) = tspan(1);
    y(1, :) = y0(:)';

    for n = 1:nsteps
        k1 = f(t(n), y(n, :));
        k2 = f(t(n) + 0.5*h, y(n, :) + 0.5*h*k1);
        k3 = f(t(n) + 0.5*h, y(n, :) + 0.5*h*k2);
        k4 = f(t(n) + h, y(n, :) + h*k3);

        y(n+1, :) = y(n, :) + h/6 * (k1 + 2*k2 + 2*k3 + k4);
        % max yta = 0
%        if y(n+1,6) > 0      
%            y(n+1,6) = 0;   
%            y(n+1,8) = 0;    
%        end
        t(n+1) = t(n) + h;
    end
end
