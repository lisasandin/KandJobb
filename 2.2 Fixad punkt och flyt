%% Animation

N = length(t);

figure
axis equal; grid on; hold on
xlim([-20 20]); ylim([-60 10]);
xlabel("X [m]"); ylabel("Z [m]");
title("Animation av boj och linor")

plot(r_botten(1), r_botten(2), 'ks', 'MarkerSize', 10, 'LineWidth', 2)

h_boj = patch(horn_varld_boj(1,:), horn_varld_boj(2,:), 'b', 'FaceAlpha', 0.5);
h_line1 = plot([r_botten(1), x_hist_boj(1)], [r_botten(2), z_hist_boj(1)], 'k--', 'LineWidth', 1.5);
h_line2 = plot([x_hist_boj(1), x_hist_turbin(1)], [z_hist_boj(1), z_hist_turbin(1)], 'g--', 'LineWidth', 1.5);
