    % turbin
    x_turbin = x_hist_turbin(i);
    z_turbin = z_hist_turbin(i);
    horn_varld_turbin = horn_turbin + [x_turbin; z_turbin];
    
    % mitten på bojens kanter
    mitten_ovre_boj = (horn_varld_boj(:,3) + horn_varld_boj(:,4)) / 2;
    mitten_undre_boj = (horn_varld_boj(:,1) + horn_varld_boj(:,2)) / 2;

    % mitten på turbinens kanter
    mitten_ovre_turbin = (horn_varld_turbin(:,3) + horn_varld_turbin(:,4)) / 2;
    mitten_undre_turbin = (horn_varld_turbin(:,1) + horn_varld_turbin(:,2)) / 2;

    % Kopplar ihop bojen, turbinen och linorna
    set(h_boj, 'XData', horn_varld_boj(1,:), 'YData', horn_varld_boj(2,:));
