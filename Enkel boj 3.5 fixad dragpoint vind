%% Funktioner

function dydt = f(~, y, V_boj, m_boj, bredd_turbin, djup_turbin, hojd_turbin, m_turbin, mc_turbin_local, ...
                  r_botten, L0_1, L0_2, k, U0, D, U10, b, ...
                  A_boj, Cd, p_luft, p_vatten, Cs, horn_boj, horn_turbin)

    % Boj
    r_boj = y(1:2)';
    v_boj = y(3:4)';
    fpunkt_ner_boj = r_boj + (horn_boj(:,1) + horn_boj(:,2)) / 2;  % nedre mitten
    fpunkt_upp_boj = r_boj + (horn_boj(:,3) + horn_boj(:,4)) / 2;  % övre mitten

    % Turbin
    r_turbin = y(5:6)';
    theta    = y(7);
    v_turbin = y(8:9)';
    omega    = y(10);

    % Rotationsmatris
    R = [cos(theta), sin(theta);
         -sin(theta),  cos(theta)];

    % Rotera hörn
    horn_roterade = R * horn_turbin;
    horn_varld_turbin = horn_roterade + r_turbin;

    % Fästpunkt turbin 
    fpunkt_turbin = r_turbin + (horn_roterade(:,1) + horn_roterade(:,2)) / 2;

    % Ändra masscentrum allt eftersom turbinen förflyttas och roteras
    mc_turbin = r_turbin + R * mc_turbin_local;

    % Aproximativ area mot ström
    submerged_h = abs(horn_varld_turbin(2,2));
    A_turbin_submerged = submerged_h * djup_turbin;
    A_turbin_submerged_eff = A_turbin_submerged*abs(cos(theta));
    

    % Aproximativ area mot vind
    above_h = abs(horn_varld_turbin(1,2));
    above_x = abs(horn_varld_turbin(1,1));
    A_turbin_above = above_h * djup_turbin;
    A_turbin_above_eff = A_turbin_above*abs(cos(theta));
    drag_point_vind = dragpoint_vind(horn_varld_turbin);


    % Polygon beräkning
    [centroid, V_turbin, drag_point] = centroid_volym_dragpoint(horn_varld_turbin, djup_turbin);
    
    
    % Beräkna ström vid det aktuella djupet
    U_strom_turbin = strom(centroid(2), U0, D);
    U_strom_boj = strom(r_boj(2), U0, D);

    % Beräkna vind vid den aktuell höjden approximation borde delas upp
    U_vind_turbin = vind(drag_point_vind(2), U10, b);

    % Krafter på bojen
    Fdrag_boj  = F_drag(U_strom_boj, v_boj, A_boj, Cd, p_vatten);
    Fflyt_boj  = flyt(V_boj);
    Ftyngd_boj = tyngd(m_boj);
    Flin_1     = F_lin(fpunkt_upp_boj, fpunkt_turbin, L0_1, k);
    Flin_2     = F_lin(fpunkt_ner_boj, r_botten, L0_2, k);

    Ftot_boj = Fflyt_boj + Ftyngd_boj + Flin_1 + Flin_2 + Fdrag_boj;
    a_boj    = Ftot_boj / m_boj;

    % Krafter på turbinen
    Fdrag_turbin_strom  = F_drag(U_strom_turbin, v_turbin, A_turbin_submerged_eff, Cd, p_vatten);
    Fdrag_turbin_vind = F_drag(U_vind_turbin, v_turbin, A_turbin_above_eff, Cs, p_luft);
    Fflyt_turbin  = flyt(V_turbin);
    Ftyngd_turbin = tyngd(m_turbin);
    Flin_turbin   = F_lin(fpunkt_turbin, fpunkt_upp_boj, L0_1, k);

    Ftot_turbin = Fflyt_turbin + Ftyngd_turbin + Flin_turbin + Fdrag_turbin_strom + Fdrag_turbin_vind;
    a_turbin    = Ftot_turbin / m_turbin;

    % Vridmoment  M = r x F  
    arm_lin  = fpunkt_turbin - mc_turbin;
    M_lin    = moment(Flin_turbin, arm_lin);

    % Vridmoment från dragkraft
    arm_drag_strom = drag_point - mc_turbin;
    M_drag_strom   = moment(Fdrag_turbin_strom, arm_drag_strom);

    arm_drag_vind = drag_point_vind - mc_turbin;
    M_drag_vind = moment(Fdrag_turbin_vind, arm_drag_vind);


    % Vridmoment från lyftkraft
    arm_flyt = centroid - mc_turbin;
    M_flyt = moment(Fflyt_turbin, arm_flyt);

    % Steiners Formel
    d = norm(mc_turbin_local);
    I_turbin = m_turbin/12 * (bredd_turbin^2 + hojd_turbin^2) + m_turbin * d^2;
    
    % Approximativ dämpning från vatten fixa sen
    %c_omega = 0.5 * p * Cd * A_turbin * (hojd_turbin/2)^3;
    %M_damp = -c_omega * abs(omega) * omega;

    alpha = (M_lin + M_flyt + M_drag_strom + M_drag_vind) / I_turbin;

    % [x_boj; z_boj; vx_boj; vz_boj; x_turbin; z_turbin; theta; vx_turbin; vz_turbin; omega]
    dydt = [ ...
    v_boj;          % dx_boj
    a_boj;          % dv_boj
    v_turbin;       % dx_turbin
    omega;          % dtheta
    a_turbin;       % dv_turbin
    alpha           % domega
];
    dydt = dydt(:)';
end

% Tyngdkraft
function Ftyngd = tyngd(m)
    g = 9.82;
    Ftyngd = [0; -m * g];      
end

% Arkimedes princip
function Fflyt = flyt(V)  % Varje kraft är en 2x1 vektor med [x-komponent; z-komponent]
    p = 1000;
    g = 9.82;
    Fflyt = [0; p * g * V];  
end

% Dragkraft 
function Fdrag = F_drag(U_strom, v, A, Cd, p)
    v_rel = U_strom - v;        
    Fdrag = 0.5 * p * A * Cd * norm(v_rel) .* v_rel;
end

% Hookes lag med dämpning
function Flin = F_lin(r1, r0, L0, k)

    r1 = r1(:);
    r0 = r0(:);

    d = r1 - r0;
    L = norm(d);

    if L == 0
        Flin = [0; 0];
        return
    end

    e = d / L;

    % Fjäder
    T = k * max(L - L0, 0);

    %  Dämpning fixa sen
    % c = 5e3;
    % T = T + c * (L - L0);

    Flin = -T * e;
end

function Moment = moment(F, r) 
    Moment = F(1) * r(2) - F(2) * r(1); 
end



% Funkar endast för polygon approximation av en dragpoint borde integreras
function [centroid, volym, drag_point] = centroid_volym_dragpoint(horn_varld, djup)

    % Börja med att definera det som är under ytan

    % Lista för nedsänkta punkter
    pts = [];

    N = size(horn_varld, 2);

    for i = 1:N
        p1 = horn_varld(:, i);
        p2 = horn_varld(:, mod(i, N) + 1);

        z1 = p1(2);
        z2 = p2(2);

        % Om punkt är under ytan --> behåll
        if z1 < 0
            pts = [pts, p1];
        end

        % Om kanten korsar vattenytan → lägg till skärningspunkt
        if (z1 < 0 && z2 > 0) || (z1 > 0 && z2 < 0)
            t = z1 / (z1 - z2);  % linjär interpolation
            p_int = p1 + t * (p2 - p1);
            pts = [pts, p_int];
        end
    end

    % Om inget är under vatten
    if isempty(pts)
        centroid = [NaN; NaN];
        volym = 0;
        drag_point = 0;
        return
    end
    
    % Därefter beräkna centroiden dela upp i trianglar

    x = pts(1,:);
    z = pts(2,:);

    A = 0;
    Cx = 0;
    Cz = 0;

    for i = 1:length(x)
        j = mod(i, length(x)) + 1;
        cross = x(i)*z(j) - x(j)*z(i);
        A = A + cross;
        Cx = Cx + (x(i) + x(j)) * cross;
        Cz = Cz + (z(i) + z(j)) * cross;
    end

    A = A / 2;
    volym = abs(A)*djup;

    if A == 0
        centroid = mean(pts, 2); % fallback
    else
        Cx = Cx / (6*A);
        Cz = Cz / (6*A);
        centroid = [Cx; Cz];
    end

    tol = 1e-6;
    x_front = min(pts(1,:));
    
    front_pts = pts(:, abs(pts(1,:) - x_front) < tol);
    
    if isempty(front_pts)
        drag_x = x_front;
    else
        drag_x = mean(front_pts(1,:));
    end
    
    drag_point = [drag_x; centroid(2)];
end

function drag_point_vind = dragpoint_vind(horn_varld)

    % Lista för punkter ovanför ytan
    pts = [];

    N = size(horn_varld, 2);

    for i = 1:N
        p1 = horn_varld(:, i);
        p2 = horn_varld(:, mod(i, N) + 1);

        z1 = p1(2);
        z2 = p2(2);

        % Om punkt är ovanför ytan --> behåll
        if z1 > 0
            pts = [pts, p1];
        end

        % Om kanten korsar vattenytan → lägg till skärningspunkt
        if (z1 < 0 && z2 > 0) || (z1 > 0 && z2 < 0)
            t = z1 / (z1 - z2);  % linjär interpolation
            p_int = p1 + t * (p2 - p1);
            pts = [pts, p_int];
        end
    end

    % Om inget är ovanför vatten
    if isempty(pts)
        drag_point_vind = [NaN; NaN];
        return
    end

    % Beräkna centroid (samma som du gjorde tidigare)
    x = pts(1,:);
    z = pts(2,:);

    A = 0;
    Cx = 0;
    Cz = 0;

    for i = 1:length(x)
        j = mod(i, length(x)) + 1;
        cross = x(i)*z(j) - x(j)*z(i);
        A = A + cross;
        Cx = Cx + (x(i) + x(j)) * cross;
        Cz = Cz + (z(i) + z(j)) * cross;
    end

    A = A / 2;

    if A == 0
        centroid = mean(pts, 2);
    else
        Cx = Cx / (6*A);
        Cz = Cz / (6*A);
        centroid = [Cx; Cz];
    end

    % Samma logik för x-position (front)
    tol = 1e-6;
    x_front = min(pts(1,:));
    
    front_pts = pts(:, abs(pts(1,:) - x_front) < tol);
    
    if isempty(front_pts)
        drag_x = x_front;
    else
        drag_x = mean(front_pts(1,:));
    end

    drag_point_vind = [drag_x; centroid(2)];
end

% Ström beroende på djup 
function U_strom = strom(z, U0, D)
    U_strom = [U0 * exp(z / D); 0];
end

% Vindhastighet beroende på höjd över havet
function U_vind = vind(z, U10, b)
    U_vind = [U10 * (z/10)^b; 0];
end


function [t, y] = rk4(f, tspan, y0, h)
    nsteps = floor((tspan(2) - tspan(1)) / h);
    m = length(y0);

    t = zeros(nsteps + 1, 1);
    y = zeros(nsteps + 1, m);

    t(1) = tspan(1);
    y(1, :) = y0(:)';

    for n = 1:nsteps
        k1 = f(t(n), y(n, :));
        k2 = f(t(n) + 0.5*h, y(n, :) + 0.5*h*k1);
        k3 = f(t(n) + 0.5*h, y(n, :) + 0.5*h*k2);
        k4 = f(t(n) + h, y(n, :) + h*k3);

        y(n+1, :) = y(n, :) + h/6 * (k1 + 2*k2 + 2*k3 + k4);
        % max yta = 0
%        if y(n+1,6) > 0      
%            y(n+1,6) = 0;   
%            y(n+1,8) = 0;    
%        end
        t(n+1) = t(n) + h;
    end
end
