k_fjader = 1e5;
V_boj = 12;
m_boj = 800;
r_boj = [0; -9];       % bojens position
v_boj = [0; 0];
y = [r_boj; v_boj];    % totalt
L0_2 = 40;

r_botten = [0; -50];   % bottenpunkt

r_turbin = [5; 0];     % Turbinens position
L0_1 = 10;


% Define IVP
h = 0.01;
t_max = 20;
tspan = [0, t_max];

z_hist = [];
x_hist = [];


% Solve IVP
y0 = [r_boj; v_boj];    % [x; z; vx; vz] 
f_handle = @(t, y) f(t, y, V_boj, m_boj, r_turbin, r_botten, L0_1, L0_2, k_fjader); % packar in alla konstanter så RK4 kan anropas
[t, y_out] = rk4(f_handle, tspan, y0, h);

x_hist = y_out(:, 1);
z_hist = y_out(:, 2);


function Fflyt = flyt(V)  % Varje kraft är en 2x1 vektor med [x-komponent; z-komponent]
    p = 1000;
    g = 9.82;
    Fflyt = [0; p * g * V];  
end

function Ftyngd = tyngd(m)
    g = 9.82;
    Ftyngd = [0; -m * g];      
end

function Flin = F_lin(r1, r0, L0, k)
    r1 = r1(:); 
    r0 = r0(:);   
    d = r1 - r0;  % vektor från fäste till boj
    L = norm(d);  % linans nuvarande längd           
    e = d / L;    % enhetsvektorn (riktning)             
    T = k * max(L - L0, 0);   % kraft bara om linan är spänd
    Flin = -T * e;  % drar mot fästet
end

% ODE
function dydt = f(t, y, V_boj, m_boj, r_turbin, r_botten, L0_1, L0_2, k)
    r = y(1:2)';   % position [x; z]
    v = y(3:4)';   % hastighet [vx; vz]

    F_flyt = flyt(V_boj);
    F_tyngd = tyngd(m_boj);
    F_lin_1 = F_lin(r, r_turbin, L0_1, k);
    F_lin_2 = F_lin(r, r_botten, L0_2, k);

    F_tot = F_flyt + F_tyngd + F_lin_1 + F_lin_2;
    a = F_tot /m_boj;

    dydt= [v; a];   % [dx/dt; dz/dt; dvx/dt; dvz/dt] Kolumnvektor
    dydt = dydt(:)';    % gör om till radvektor för RK4
   
end

% RK4
function [t, y] = rk4(f, tspan, y0, h)

nsteps = floor((tspan(2) - tspan(1)) / h);
m = length(y0);
t = zeros(1, nsteps + 1);   % skapar tom array
y = zeros(nsteps + 1, m);   % tom array

t(1) = tspan(1);
y(1,:) = y0;

for n = 1 : length(t) - 1
    k1 = f(t(n), y(n,:));
    k2 = f(t(n) + 1/2 * h, y(n,:) + 1/2 * h * k1);
    k3 = f(t(n) + 1/2 * h, y(n,:) + 1/2 * h * k2);
    k4 = f(t(n) + h, y(n,:) + h * k3);

    y(n+1,:) = y(n,:) + h / 6 * (k1 + 2 * k2 + 2 * k3 + k4);
    t(n+1) = t(n) + h;
end

end


